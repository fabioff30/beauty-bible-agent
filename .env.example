# Beauty Bible Agent - Environment Variables

# ==========================================
# TELEGRAM
# ==========================================
# Obtenha seu token com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# AI PROVIDER (choose one)
# ==========================================

# Option 1: OpenRouter (recommended - simple, free tier available)
# Get key at: https://openrouter.ai/keys
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=openai/gpt-4o-mini

# Option 2: OpenAI directly
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# AI_MODEL=gpt-4o-mini

# Option 3: Google Gemini (free tier)
# AI_PROVIDER=gemini
# GOOGLE_API_KEY=your_google_api_key_here
# AI_MODEL=gemini-1.5-flash

# ==========================================
# VISION MODEL (for skin photo analysis)
# ==========================================
# OpenRouter vision models:
#   openai/gpt-4o             (best quality)
#   google/gemini-2.0-flash   (fast + free on some tiers)
#   openai/gpt-4o-mini        (cheapest)
VISION_MODEL=openai/gpt-4o-mini

# ==========================================
# OPTIONAL
# ==========================================
# Debug mode
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
