# Beauty Bible Agent - Environment Variables Template
# Copie para .env.local e preencha os valores reais. .env.local é ignorado pelo git.

# ==========================================
# TELEGRAM
# ==========================================
# Obtenha seu token com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# AI PROVIDER — Google Gemini direct
# ==========================================
# Obtenha sua key em https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo conversacional da BB. Sem prefixo "google/" (formato Gemini puro).
# Sugestões: gemini-2.5-flash, gemini-3.1-flash-lite, gemini-3-flash
AI_MODEL=gemini-3.1-flash-lite

# Modelo de visão (análise de pele). Pode ser o mesmo.
VISION_MODEL=gemini-3.1-flash-lite

# Modelo do dream job (consolidação noturna). Opcional — fallback para AI_MODEL.
# DREAM_MODEL=gemini-3.1-flash-lite

# ==========================================
# DATABASE (SQLCipher)
# ==========================================
# Senha de criptografia do banco. Gere com: openssl rand -base64 48
# OBRIGATÓRIO em produção. NÃO mude depois que o banco existir (perde dados).
SQLCIPHER_KEY=change-me-to-a-32+-char-random-string

# Diretório do .db (no VPS: aponta para o volume persistente)
# Default: ./data
# DATA_DIR=/data

# ==========================================
# DREAM JOB (sleep-time consolidation)
# ==========================================
# Cron expression (5 fields: minute hour day month dow). Default: 03:00 daily.
DREAM_CRON=0 3 * * *
DREAM_LOOKBACK_HOURS=24

# ==========================================
# OPTIONAL
# ==========================================
DEBUG=false
LOG_LEVEL=INFO
