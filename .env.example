# Beauty Bible Agent - Environment Variables Template
# Copie para .env.local e preencha os valores reais. .env.local é ignorado pelo git.

# ==========================================
# TELEGRAM
# ==========================================
# Obtenha seu token com @BotFather no Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# AI PROVIDER
# ==========================================
# Provider: openrouter | openai | gemini
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Modelo conversacional da BB
AI_MODEL=google/gemini-2.5-flash

# Modelo de visão para análise de pele (pode ser o mesmo)
VISION_MODEL=google/gemini-2.5-flash

# ==========================================
# DATABASE (SQLCipher)
# ==========================================
# Senha de criptografia do banco. Gere com: openssl rand -base64 48
# OBRIGATÓRIO em produção. Mantenha fora do repo.
SQLCIPHER_KEY=change-me-to-a-32+-char-random-string

# Diretório do .db (no VPS: aponta para o volume persistente)
# Default: ./data
# DATA_DIR=/data

# ==========================================
# DREAM JOB (sleep-time consolidation)
# ==========================================
# Cron expression (5 fields: minute hour day month dow). Default: 03:00 daily.
DREAM_CRON=0 3 * * *
# How far back to look for active users on each run.
DREAM_LOOKBACK_HOURS=24
# Optional: use a cheaper model for batch consolidation. Falls back to AI_MODEL.
# DREAM_MODEL=google/gemini-2.5-flash

# ==========================================
# OPTIONAL
# ==========================================
DEBUG=false
LOG_LEVEL=INFO
